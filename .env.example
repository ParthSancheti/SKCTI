# ── Firebase (Project settings → General → Your apps → Web app → Config) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Admin bootstrap ──
# Your Google account email(s), comma-separated. Used the first time you hit
# "Initialize" on /admin — after that the list lives in Firestore (editable
# from Admin → Mission Control).
NEXT_PUBLIC_ADMIN_EMAILS=you@gmail.com

# ── Gemini (https://aistudio.google.com/apikey) — server-side only ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
